# DataAgent 部署环境变量

# MySQL root 密码
MYSQL_ROOT_PASSWORD=root

# ============================================
# AI 服务配置 (任选一个 LLM 提供商即可)
# ============================================

# 方式一：阿里云通义千问 DashScope
# 获取：https://dashscope.aliyun.com/
QWEN_API_KEY=
QWEN_MODEL=qwen-turbo

# 方式二：DeepSeek
# 获取：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# LLM 提供商选择 (qwen / deepseek，不填默认 qwen)
LLM_PROVIDER=qwen

# Embedding 模型 (qwen 专用)
EMBEDDING_MODEL=text-embedding-v2

# ============================================
# 对象存储 OSS (可选，不填使用本地存储)
# ============================================
OSS_ENABLED=false
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=dataagent-files

# Redis 配置 (默认即可)
REDIS_HOST=redis
REDIS_PORT=6379

# JWT 密钥 (生产环境请修改)
JWT_SECRET=DataAgentSecretKey2024ForJWTTokenGenerationAndValidation
JWT_ACCESS_TOKEN_EXPIRE=7200
JWT_REFRESH_TOKEN_EXPIRE=604800
